# ===== PRODUCTION backend env (Render/Railway) =====
# Set these in your host's dashboard (never commit real values).

APP_ENV=production

# --- AI: your OpenAI key (you pay AI, customers pay you more) ---
OPENAI_API_KEY=sk-...           # used for gpt-4o-mini scoring AND Whisper transcription
TRANSCRIPTION_PROVIDER=openai   # cloud Whisper; do NOT use 'local' in the cloud
# (Leave LLM_BASE_URL unset to use OpenAI. To cut costs you can point scoring at
#  Groq instead: LLM_BASE_URL=https://api.groq.com/openai/v1, LLM_API_KEY=gsk_...,
#  LLM_MODEL=llama-3.3-70b-versatile — but keep OPENAI_API_KEY set for Whisper.)

# --- Database: managed Postgres connection string ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Auth: MUST be strong in production (>=32 chars) ---
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-with-a-32+char-random-secret
FREE_CREDITS_ON_SIGNUP=3

# --- Stripe (LIVE or TEST keys) ---
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...           # from the Stripe webhook you create
STRIPE_SUBSCRIPTION_PRICE_ID=price_...    # your recurring Pro price
PAY_PER_USE_AMOUNT_CENTS=99

# --- URLs / CORS (your deployed frontend) ---
FRONTEND_URL=https://your-app.vercel.app
# Optional: extra allowed origins, comma-separated (e.g. a custom domain)
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com

# --- Uploads / limits ---
MAX_UPLOAD_MB=200
MAX_ACTIVE_VIDEO_JOBS=5
