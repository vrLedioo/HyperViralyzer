# --- AI provider (choose ONE setup) ---
#
# Option A — OpenAI cloud: set your key, leave LLM_BASE_URL empty.
OPENAI_API_KEY=your_openai_api_key_here
#
# Option B — KEYLESS LOCAL (no OpenAI key): run Ollama + faster-whisper.
#   ollama pull llama3.2:3b   (small & fast; avoid 7B+ "thinking" models on CPU)
#   then uncomment:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2:3b
# LLM_DISABLE_THINKING=true
# TRANSCRIPTION_PROVIDER=local      # faster-whisper, no key (default: openai)
# LOCAL_WHISPER_MODEL=base
#
# Option C — other OpenAI-compatible API (e.g. Groq free tier):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# SQLite by default; swap for a Postgres URL in production.
DATABASE_URL=sqlite:///./video_analyzer.db

# --- Environment ---
# "development" (default) relaxes safety guards for local work. Set to
# "production" on a real deployment — the app then REFUSES to start with a weak
# JWT_SECRET or with a payment provider enabled but no webhook signing secret.
APP_ENV=development

# --- Auth ---
# Use a long random string (>= 32 chars). Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# In production a weak/default secret here is a fatal startup error.
JWT_SECRET=change-me-to-a-long-random-secret-string
FREE_CREDITS_ON_SIGNUP=10
# IDEA_CREDIT_COST=1           # credits per idea report
# VIDEO_CREDIT_COST=5          # credits per video report (includes transcription)

# --- Payments ---
# "none" (default), "lemonsqueezy", or "stripe".
# Lemon Squeezy is a Merchant of Record that works where Stripe doesn't (e.g.
# Kosovo) and handles tax/VAT + payouts. See docs/GO-LIVE.md.
PAYMENT_PROVIDER=none

# Lemon Squeezy (when PAYMENT_PROVIDER=lemonsqueezy). Credit amounts per plan/pack
# live in backend/plans.py; set one variant id per product you actually sell:
# LEMONSQUEEZY_API_KEY=...
# LEMONSQUEEZY_STORE_ID=12345
# LEMONSQUEEZY_WEBHOOK_SECRET=...                # signing secret you set on the webhook
# LS_VARIANT_CREATOR=111111                      # Creator plan (€14/mo, 150 credits)
# LS_VARIANT_PRO=222222                          # Pro plan (€29/mo, 500 credits)
# LS_VARIANT_AGENCY=333333                       # Agency plan (€79/mo, 2000 credits)
# LS_VARIANT_PACK_SMALL=444444                   # 50-credit pack (€9)
# LS_VARIANT_PACK_LARGE=555555                   # 200-credit pack (€29)

# Stripe (when PAYMENT_PROVIDER=stripe):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...                # from `stripe listen`
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...
# PAY_PER_USE_AMOUNT_CENTS=99

# --- URLs ---
FRONTEND_URL=http://localhost:3000

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=200
