# ===== PRODUCTION frontend env (Vercel) =====
# Set in Vercel → Project → Settings → Environment Variables.

# Public URL of your deployed backend (Render/Railway).
NEXT_PUBLIC_API_URL=https://vidanalyzer-api.onrender.com

# Paddle client-side token (PUBLIC, safe to expose). REQUIRED for checkout to open —
# Paddle Billing opens the checkout overlay with Paddle.js, which needs this token.
# Create it in Paddle → Developer tools → Authentication → Client-side tokens.
# Use the `live_` token in production (`test_` for sandbox).
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: set to "sandbox" to test against Paddle's sandbox (default = live).
# NEXT_PUBLIC_PADDLE_ENV=sandbox
